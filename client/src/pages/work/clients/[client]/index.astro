---
import { getFirstProjectSlug, getProjectRoutes } from '@services/SanityClient.ts';

export const prerender = false;
export const getStaticPaths = async () => getProjectRoutes();

interface Params {client: string;}
const { client } = Astro.params as Params;
const projectSlug = await getFirstProjectSlug(client);
return Astro.redirect(`/work/clients/${client}/projects/${projectSlug}`)
---
