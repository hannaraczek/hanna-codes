---
import Menu from './Menu.astro';
import Navigation from './Navigation.astro';
import ThemeIcon from './ThemeIcon.astro';
---
<header>
    <div>
        <ThemeIcon/>
        <Menu/>
    </div>
    <nav>
        <Navigation/>
    </nav>
</header>
<style>
    div {
        display: flex;
        flex-direction: row;
        gap: 1rem;
        justify-content: flex-end;
    }
</style>
